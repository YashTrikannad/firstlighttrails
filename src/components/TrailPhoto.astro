---
const base = (import.meta.env.PUBLIC_PHOTOS_BASE ?? '').replace(/\/$/, '');

interface Props {
  photo: string;
  caption?: string;
  alt?: string;
  wide?: boolean;
}
const { photo, caption, alt = caption ?? '', wide = false } = Astro.props;
const src = `${base}/photos/${photo}.webp`;
---

<figure class:list={['trail-photo', { 'trail-photo--wide': wide }]}>
  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .trail-photo {
    margin: 3rem 0;
  }

  /* full viewport bleed for panoramas */
  .trail-photo--wide {
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    margin: 3rem 0;
  }

  .trail-photo img {
    width: 100%;
    display: block;
    border-radius: 3px;
    max-height: 75vh;
    object-fit: cover;
  }

  .trail-photo--wide img {
    border-radius: 0;
    max-height: 60vh;
  }

  .trail-photo figcaption {
    font-family: system-ui, sans-serif;
    font-size: 0.78rem;
    color: #a0b09a;
    margin-top: 0.6rem;
    text-align: center;
    font-style: italic;
    letter-spacing: 0.02em;
  }
</style>
