---
interface Props {
  name: string;
  facing?: string;     // e.g. "west", "northeast"
  bestTime?: string;   // e.g. "30 min after sunrise, mid-October"
  notes?: string;
}

const { name, facing, bestTime, notes } = Astro.props;
---

<aside class="photo-spot">
  <div class="photo-spot__label">Photo Spot</div>
  <h3 class="photo-spot__name">{name}</h3>
  {(facing || bestTime) && (
    <dl class="photo-spot__meta">
      {facing && (
        <div class="photo-spot__row">
          <dt>Facing</dt>
          <dd class="photo-spot__capitalize">{facing}</dd>
        </div>
      )}
      {bestTime && (
        <div class="photo-spot__row">
          <dt>Best Time</dt>
          <dd>{bestTime}</dd>
        </div>
      )}
    </dl>
  )}
  {notes && <p class="photo-spot__notes"><slot>{notes}</slot></p>}
  {!notes && <slot />}
</aside>

<style>
  .photo-spot {
    margin: 1.75rem auto;
    max-width: 65ch;
    padding: 1.25rem 1.5rem;
    background: var(--bg-card, #1a261a);
    border: 1px solid var(--border, #2a3a2a);
    border-left: 3px solid var(--accent, #c8b89a);
    border-radius: 4px;
  }

  .photo-spot__label {
    font-family: system-ui, sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent, #c8b89a);
    margin-bottom: 0.5rem;
  }

  .photo-spot__name {
    font-family: Georgia, serif;
    font-size: 1.15rem;
    font-weight: normal;
    letter-spacing: 0.02em;
    color: var(--text-body, #e0d8c8);
    margin: 0 0 0.85rem;
    border: none;
    padding: 0;
  }

  .photo-spot__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin: 0 0 0.85rem;
    font-family: system-ui, sans-serif;
  }

  .photo-spot__row {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .photo-spot__row dt {
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--label, #8a9a8a);
  }

  .photo-spot__row dd {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-body, #e0d8c8);
  }

  .photo-spot__capitalize { text-transform: capitalize; }

  .photo-spot__notes {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-body, #e0d8c8);
    margin: 0;
  }
</style>
