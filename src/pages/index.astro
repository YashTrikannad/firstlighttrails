---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import { HIKING_LISTS } from '../data/hikingLists';
import { getCollection } from 'astro:content';

const trails = await getCollection('trails');
const photosBase = (import.meta.env.PUBLIC_PHOTOS_BASE ?? '').replace(/\/$/, '');

// Build lookup: trailSlug → { summary, coverPhoto }
const trailInfo = Object.fromEntries(
  trails.map(t => [t.id, { summary: t.data.summary, coverPhoto: t.data.coverPhoto ?? null }])
);

// Enrich peaks with trail data so the map script has everything it needs
const enrichedLists = HIKING_LISTS.map(list => ({
  ...list,
  peaks: list.peaks.map(peak => ({
    ...peak,
    trail: peak.trailSlug ? {
      slug: peak.trailSlug,
      summary: trailInfo[peak.trailSlug]?.summary ?? null,
      coverPhoto: trailInfo[peak.trailSlug]?.coverPhoto ?? null,
    } : null,
  })),
}));

const hikingListsJson = JSON.stringify(enrichedLists);
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;
---

<Base title="First Light Trails">
  <Fragment slot="head">
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.css" rel="stylesheet" />
    <script is:inline src="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.js"></script>
    <style>
      body { overflow: hidden; }
      #map { width: 100%; height: 100vh; }

      .list-panel {
        position: absolute;
        bottom: 2.5rem;
        left: 1.5rem;
        z-index: 10;
        background: var(--bg-overlay);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 1rem 1.25rem;
        min-width: 220px;
        backdrop-filter: blur(8px);
      }

      .list-panel-header {
        font-family: system-ui, sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 0.75rem;
      }

      .list-btn {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        background: none;
        border: 1px solid var(--border);
        border-radius: 3px;
        color: var(--text);
        font-family: system-ui, sans-serif;
        font-size: 0.82rem;
        letter-spacing: 0.04em;
        padding: 0.5rem 0.75rem;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s, color 0.15s;
        text-align: left;
        margin-bottom: 0.4rem;
      }

      .list-btn:last-child { margin-bottom: 0; }

      .list-btn:hover {
        background: var(--bg-elevated);
        border-color: var(--border-hover);
      }

      .list-btn.active {
        background: var(--bg-elevated);
        border-color: var(--accent);
        color: var(--accent);
      }

      .list-btn .badge {
        font-size: 0.7rem;
        background: var(--bg-elevated);
        color: var(--text-muted);
        padding: 0.1rem 0.4rem;
        border-radius: 2px;
        margin-left: 0.5rem;
        flex-shrink: 0;
      }

      .list-btn.active .badge {
        background: var(--bg-card);
        color: var(--accent-soft);
      }

      /* Mapbox popup base */
      .mapboxgl-popup-content {
        background: var(--popup-bg) !important;
        border: 1px solid var(--popup-border);
        border-radius: 6px;
        padding: 0 !important;
        color: var(--text);
        font-family: Georgia, serif;
        box-shadow: 0 6px 24px rgba(0,0,0,0.18);
        overflow: hidden;
        min-width: 220px;
        max-width: 260px;
      }

      .mapboxgl-popup-tip { display: none; }

      .mapboxgl-popup-close-button {
        color: var(--text-muted);
        font-size: 1.1rem;
        padding: 0.3rem 0.5rem;
        z-index: 1;
        background: var(--popup-bg);
        border-radius: 0 6px 0 4px;
      }

      /* Simple popup (no trail guide) */
      .peak-popup {
        padding: 0.75rem 1rem;
      }

      .peak-popup strong {
        display: block;
        color: var(--accent);
        font-size: 0.95rem;
        margin-bottom: 0.25rem;
      }

      .peak-popup .elev {
        font-family: system-ui, sans-serif;
        font-size: 0.78rem;
        color: var(--text-muted);
        letter-spacing: 0.04em;
      }

      /* Rich popup (has trail guide) */
      .peak-popup--trail .popup-img {
        width: 100%;
        height: 130px;
        object-fit: cover;
        display: block;
      }

      .peak-popup--trail .popup-img-placeholder {
        width: 100%;
        height: 130px;
        background: var(--bg-elevated);
      }

      .peak-popup--trail .popup-body {
        padding: 0.75rem 1rem 0.9rem;
      }

      .peak-popup--trail strong {
        display: block;
        font-size: 0.95rem;
        color: var(--accent);
        margin-bottom: 0.2rem;
      }

      .peak-popup--trail .elev {
        font-family: system-ui, sans-serif;
        font-size: 0.72rem;
        color: var(--text-muted);
        letter-spacing: 0.04em;
        margin-bottom: 0.5rem;
        display: block;
      }

      .peak-popup--trail .popup-summary {
        font-family: system-ui, sans-serif;
        font-size: 0.78rem;
        color: var(--text-subtle);
        line-height: 1.5;
        margin-bottom: 0.75rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .peak-popup--trail .popup-link {
        font-family: system-ui, sans-serif;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        text-decoration: none;
        border: 1px solid var(--accent);
        padding: 0.3rem 0.7rem;
        border-radius: 3px;
        display: inline-block;
        transition: background 0.15s, color 0.15s;
      }

      .peak-popup--trail .popup-link:hover {
        background: var(--accent);
        color: var(--bg);
      }

      .mapboxgl-ctrl-attrib {
        background: var(--bg-overlay) !important;
      }
    </style>
  </Fragment>

  <Nav overlay={true} />
  <div id="map"></div>

  <div class="list-panel">
    <div class="list-panel-header">Explore by List</div>
    {HIKING_LISTS.map(list => (
      <button class="list-btn" data-list-id={list.id}>
        {list.name}
        <span class="badge">{list.peaks.length} peaks</span>
      </button>
    ))}
  </div>

  <script define:vars={{ hikingListsJson, mapboxToken, photosBase }}>
    mapboxgl.accessToken = mapboxToken;
    const hikingLists = JSON.parse(hikingListsJson);

    const map = new mapboxgl.Map({
      container: 'map',
      style: 'mapbox://styles/mapbox/outdoors-v12',
      center: [-71.5, 44.0],
      zoom: 7,
      minZoom: 4,
    });

    map.addControl(new mapboxgl.NavigationControl(), 'bottom-right');

    let activeMarkers = [];
    let activeListId = null;

    function clearMarkers() {
      activeMarkers.forEach(m => m.remove());
      activeMarkers = [];
    }

    function markerColor() {
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? '#c8b89a' : '#7a5018';
    }

    function buildPopupHTML(peak) {
      if (peak.trail) {
        const imgHTML = peak.trail.coverPhoto
          ? `<img class="popup-img" src="${photosBase}/photos/${peak.trail.coverPhoto}.webp" alt="${peak.name}" loading="lazy" />`
          : `<div class="popup-img-placeholder"></div>`;
        const summaryHTML = peak.trail.summary
          ? `<span class="popup-summary">${peak.trail.summary}</span>`
          : '';
        return `
          <div class="peak-popup peak-popup--trail">
            ${imgHTML}
            <div class="popup-body">
              <strong>${peak.name}</strong>
              <span class="elev">${peak.elevation.toLocaleString()} ft</span>
              ${summaryHTML}
              <a class="popup-link" href="/trails/${peak.trail.slug}">Trail Guide →</a>
            </div>
          </div>`;
      }

      return `
        <div class="peak-popup">
          <strong>${peak.name}</strong>
          <span class="elev">${peak.elevation.toLocaleString()} ft</span>
        </div>`;
    }

    function showList(listId) {
      const isSameList = listId === activeListId;
      clearMarkers();
      document.querySelectorAll('.list-btn').forEach(b => b.classList.remove('active'));

      if (isSameList) {
        activeListId = null;
        map.flyTo({ center: [-71.5, 44.0], zoom: 7, duration: 1000 });
        return;
      }

      activeListId = listId;
      document.querySelector(`[data-list-id="${listId}"]`)?.classList.add('active');

      const list = hikingLists.find(l => l.id === listId);
      if (!list) return;

      list.peaks.forEach(peak => {
        const popup = new mapboxgl.Popup({ offset: 20, closeButton: true, maxWidth: '260px' })
          .setHTML(buildPopupHTML(peak));

        const marker = new mapboxgl.Marker({ color: markerColor(), scale: 0.8 })
          .setLngLat(peak.coords)
          .setPopup(popup)
          .addTo(map);

        activeMarkers.push(marker);
      });

      const bounds = list.peaks.reduce((b, peak) => b.extend(peak.coords),
        new mapboxgl.LngLatBounds(list.peaks[0].coords, list.peaks[0].coords));
      map.fitBounds(bounds, { padding: 80, maxZoom: 10, duration: 1200 });
    }

    document.querySelectorAll('.list-btn').forEach(btn => {
      btn.addEventListener('click', () => showList(btn.dataset.listId));
    });
  </script>
</Base>
