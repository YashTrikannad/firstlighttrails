---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import { HIKING_LISTS } from '../data/hikingLists';
import { getCollection } from 'astro:content';

const trails = await getCollection('trails');
const photosBase = (import.meta.env.PUBLIC_PHOTOS_BASE ?? '').replace(/\/$/, '');

const featuredTrail = trails.sort((a, b) => b.data.scenicRating - a.data.scenicRating)[0] ?? null;

// Build lookup: trailSlug → { summary, coverPhoto }
const trailInfo = Object.fromEntries(
  trails.map(t => [t.id, {
    coverPhoto:   t.data.coverPhoto ?? null,
    scenicRating: t.data.scenicRating,
    difficulty:   t.data.difficulty,
  }])
);

// Enrich peaks with trail data so the map script has everything it needs
const enrichedLists = HIKING_LISTS.map(list => ({
  ...list,
  peaks: list.peaks.map(peak => ({
    ...peak,
    trail: peak.trailSlug ? {
      slug:         peak.trailSlug,
      coverPhoto:   trailInfo[peak.trailSlug]?.coverPhoto   ?? null,
      scenicRating: trailInfo[peak.trailSlug]?.scenicRating ?? null,
      difficulty:   trailInfo[peak.trailSlug]?.difficulty   ?? null,
    } : null,
  })),
}));

const hikingListsJson = JSON.stringify(enrichedLists);
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;
const trailsSearchJson = JSON.stringify(
  trails.map(t => ({ id: t.id, title: t.data.title, location: t.data.location }))
);
---

<Base title="First Light Trails">
  <Fragment slot="head">
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.css" rel="stylesheet" />
    <script is:inline src="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.js"></script>
    <style is:global>
      body { overflow: hidden; }
      #map { width: 100%; height: 100vh; }

      /* Sidebar */
      .sidebar {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 240px;
        z-index: 8;
        background: rgba(248, 246, 242, 0.62);
        border-right: 1px solid var(--border);
        backdrop-filter: blur(10px);
        display: flex;
        flex-direction: column;
        padding-top: 5.5rem;
      }

      @media (prefers-color-scheme: dark) {
        .sidebar { background: rgba(10, 10, 10, 0.58); }
      }

      .sidebar-brand {
        padding: 1.5rem 1.5rem 1.25rem;
        border-bottom: 1px solid var(--border);
      }

      .sidebar-brand p {
        font-family: Georgia, serif;
        font-style: italic;
        font-size: 0.88rem;
        color: var(--text-subtle);
        line-height: 1.55;
      }

      .sidebar-section {
        padding: 1.25rem 1.25rem 1rem;
        flex: 1;
        overflow-y: auto;
      }

      .sidebar-section-label {
        font-family: system-ui, sans-serif;
        font-size: 0.65rem;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 0.75rem;
      }

      .sidebar-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
      }

      .sidebar-stat {
        font-family: system-ui, sans-serif;
        font-size: 0.7rem;
        color: var(--text-muted);
        letter-spacing: 0.04em;
      }

      .sidebar-browse {
        font-family: system-ui, sans-serif;
        font-size: 0.65rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        text-decoration: none;
        flex-shrink: 0;
      }

      .sidebar-browse:hover { text-decoration: underline; }

      /* Sidebar search */
      .sidebar-search {
        padding: 1rem 1.25rem 0.9rem;
        border-bottom: 1px solid var(--border);
        position: relative;
      }

      .sidebar-search-input {
        width: 100%;
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 3px;
        color: var(--text);
        font-family: system-ui, sans-serif;
        font-size: 0.8rem;
        padding: 0.45rem 0.75rem;
        outline: none;
        transition: border-color 0.15s;
      }

      .sidebar-search-input:focus { border-color: var(--accent); }

      .sidebar-search-input::placeholder { color: var(--text-muted); }

      .search-results { margin-top: 0.5rem; }

      .search-result-item {
        display: block;
        padding: 0.45rem 0.6rem;
        border-radius: 3px;
        text-decoration: none;
        color: var(--text);
        font-family: system-ui, sans-serif;
        font-size: 0.8rem;
        transition: background 0.12s;
      }

      .search-result-item:hover { background: var(--bg-elevated); }

      .search-result-location {
        display: block;
        font-size: 0.63rem;
        color: var(--text-muted);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-top: 0.1rem;
      }

      .search-no-results {
        font-family: system-ui, sans-serif;
        font-size: 0.75rem;
        color: var(--text-muted);
        padding: 0.3rem 0.6rem;
      }

      .list-btn {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        background: none;
        border: 1px solid var(--border);
        border-radius: 3px;
        color: var(--text);
        font-family: system-ui, sans-serif;
        font-size: 0.82rem;
        letter-spacing: 0.04em;
        padding: 0.5rem 0.75rem;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s, color 0.15s;
        text-align: left;
        margin-bottom: 0.4rem;
      }

      .list-btn:last-child { margin-bottom: 0; }

      .list-btn:hover {
        background: var(--bg-elevated);
        border-color: var(--border-hover);
      }

      .list-btn.active {
        background: var(--bg-elevated);
        border-color: var(--accent);
        color: var(--accent);
      }

      .list-btn .badge {
        font-size: 0.7rem;
        background: var(--bg-elevated);
        color: var(--text-muted);
        padding: 0.1rem 0.4rem;
        border-radius: 2px;
        margin-left: 0.5rem;
        flex-shrink: 0;
      }

      .list-btn.active .badge {
        background: var(--bg-card);
        color: var(--accent-soft);
      }

      /* Mapbox popup */
      .mapboxgl-popup-content {
        background: var(--popup-bg) !important;
        border: 1px solid var(--popup-border);
        border-radius: 6px;
        padding: 0 !important;
        color: var(--text);
        font-family: Georgia, serif;
        box-shadow: 0 4px 16px rgba(0,0,0,0.15);
        overflow: hidden;
        width: 300px;
      }

      .mapboxgl-popup-tip { display: none; }

      .mapboxgl-popup-close-button {
        color: var(--text-muted);
        font-size: 1rem;
        line-height: 1;
        padding: 0.25rem 0.4rem;
      }

      /* Simple popup */
      .peak-popup {
        padding: 0.6rem 0.8rem;
      }

      .peak-popup strong {
        display: block;
        color: var(--accent);
        font-size: 0.88rem;
        margin-bottom: 0.15rem;
      }

      .peak-popup .elev {
        font-family: system-ui, sans-serif;
        font-size: 0.72rem;
        color: var(--text-muted);
        letter-spacing: 0.04em;
      }

      /* Rich popup — horizontal thumbnail layout */
      .peak-popup--trail {
        display: flex;
        align-items: stretch;
      }

      .peak-popup--trail .popup-img {
        width: 90px;
        min-height: 90px;
        flex-shrink: 0;
        object-fit: cover;
        display: block;
      }

      .peak-popup--trail .popup-img-placeholder {
        width: 90px;
        background: var(--bg-elevated);
        flex-shrink: 0;
      }

      .peak-popup--trail .popup-body {
        padding: 0.65rem 0.85rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.2rem;
        min-width: 0;
      }

      .peak-popup--trail strong {
        font-size: 0.92rem;
        color: var(--accent);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .peak-popup--trail .popup-difficulty {
        font-family: system-ui, sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.06em;
        text-transform: capitalize;
      }

      .peak-popup--trail .popup-scenic {
        font-size: 0.78rem;
        color: var(--accent);
        letter-spacing: 0.06em;
      }

      .peak-popup--trail .popup-link {
        font-family: system-ui, sans-serif;
        font-size: 0.68rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--accent);
        text-decoration: none;
        margin-top: 0.2rem;
      }

      .peak-popup--trail .popup-link:hover {
        text-decoration: underline;
      }

      .mapboxgl-ctrl-attrib {
        background: var(--bg-overlay) !important;
      }

      /* Vignette overlay */
      .map-vignette {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 2;
        box-shadow: inset 0 0 180px rgba(0,0,0,0.42);
      }

      /* Featured trail card */
      .featured-card {
        position: absolute;
        top: 5.5rem;
        right: 1.5rem;
        z-index: 10;
        width: 230px;
        background: var(--bg-overlay);
        border: 1px solid var(--border);
        border-radius: 4px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        backdrop-filter: blur(8px);
        transition: border-color 0.2s, transform 0.15s;
      }

      .featured-card:hover {
        border-color: var(--border-hover);
        transform: translateY(-2px);
      }

      .featured-card-img {
        width: 100%;
        height: 130px;
        object-fit: cover;
        display: block;
        opacity: 0.82;
        transition: opacity 0.2s;
      }

      .featured-card:hover .featured-card-img { opacity: 1; }

      .featured-card-img-placeholder {
        width: 100%;
        height: 130px;
        background: var(--bg-elevated);
      }

      .featured-card-body {
        padding: 0.75rem 1rem 0.9rem;
        display: flex;
        flex-direction: column;
        gap: 0.28rem;
      }

      .featured-card-label {
        font-family: system-ui, sans-serif;
        font-size: 0.62rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      .featured-card-title {
        font-size: 0.95rem;
        color: var(--accent);
        letter-spacing: 0.02em;
      }

      .featured-card-summary {
        font-family: system-ui, sans-serif;
        font-size: 0.72rem;
        color: var(--text-subtle);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-top: 0.1rem;
      }

      .featured-card-link {
        display: inline-block;
        font-family: system-ui, sans-serif;
        font-size: 0.63rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        margin-top: 0.3rem;
      }
    </style>
  </Fragment>

  <Nav overlay={true} />
  <div id="map"></div>
  <div class="map-vignette"></div>

  {featuredTrail && (
    <a href={`/trails/${featuredTrail.id}`} class="featured-card">
      {featuredTrail.data.coverPhoto
        ? <img
            class="featured-card-img"
            src={`${photosBase}/photos/${featuredTrail.data.coverPhoto}.webp`}
            alt={featuredTrail.data.title}
            loading="eager"
          />
        : <div class="featured-card-img-placeholder"></div>
      }
      <div class="featured-card-body">
        <div class="featured-card-label">Featured Trail</div>
        <div class="featured-card-title">{featuredTrail.data.title}</div>
        <div class="featured-card-summary">{featuredTrail.data.summary}</div>
        <span class="featured-card-link">Read Guide →</span>
      </div>
    </a>
  )}

  <div class="sidebar">
    <div class="sidebar-brand">
      <p>Personal trail guides from<br/>New England &amp; beyond.</p>
    </div>
    <div class="sidebar-search">
      <input
        id="trail-search"
        class="sidebar-search-input"
        type="search"
        placeholder="Search trails…"
        autocomplete="off"
      />
      <div class="search-results" id="search-results"></div>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-section-label">Explore by List</div>
      {HIKING_LISTS.map(list => (
        <button class="list-btn" data-list-id={list.id}>
          {list.name}
          <span class="badge">{list.peaks.length} peaks</span>
        </button>
      ))}
    </div>
    <div class="sidebar-footer">
      <span class="sidebar-stat">{trails.length} trail {trails.length === 1 ? 'guide' : 'guides'}</span>
      <a href="/trails" class="sidebar-browse">Browse all →</a>
    </div>
  </div>

  <script define:vars={{ hikingListsJson, mapboxToken, photosBase, trailsSearchJson }}>
    mapboxgl.accessToken = mapboxToken;
    const hikingLists = JSON.parse(hikingListsJson);

    const map = new mapboxgl.Map({
      container: 'map',
      style: 'mapbox://styles/mapbox/outdoors-v12',
      center: [-71.5, 44.0],
      zoom: 7,
      minZoom: 4,
    });

    map.addControl(new mapboxgl.NavigationControl(), 'bottom-right');

    let activeMarkers = [];
    let activeListId = null;

    function clearMarkers() {
      activeMarkers.forEach(m => m.remove());
      activeMarkers = [];
    }

    function markerColor() {
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? '#4a8a3e' : '#1e4a1a';
    }

    function buildPopupHTML(peak) {
      if (peak.trail) {
        const imgHTML = peak.trail.coverPhoto
          ? `<img class="popup-img" src="${photosBase}/photos/${peak.trail.coverPhoto}.webp" alt="${peak.name}" loading="lazy" style="width:90px;min-height:90px;max-height:110px;object-fit:cover;display:block;flex-shrink:0;" />`
          : `<div class="popup-img-placeholder" style="width:90px;min-height:90px;flex-shrink:0;background:var(--bg-elevated);"></div>`;
        const diffHTML = peak.trail.difficulty
          ? `<span class="popup-difficulty" style="color:var(--difficulty-${peak.trail.difficulty})">${peak.trail.difficulty}</span>`
          : '';
        const stars = peak.trail.scenicRating
          ? '★'.repeat(peak.trail.scenicRating) + '☆'.repeat(5 - peak.trail.scenicRating)
          : '';
        const scenicHTML = stars ? `<span class="popup-scenic">${stars}</span>` : '';
        return `
          <div class="peak-popup peak-popup--trail">
            ${imgHTML}
            <div class="popup-body">
              <strong>${peak.name}</strong>
              ${diffHTML}
              ${scenicHTML}
              <a class="popup-link" href="/trails/${peak.trail.slug}">Trail Guide →</a>
            </div>
          </div>`;
      }

      return `
        <div class="peak-popup">
          <strong>${peak.name}</strong>
          <span class="elev">${peak.elevation.toLocaleString()} ft</span>
        </div>`;
    }

    function showList(listId) {
      const isSameList = listId === activeListId;
      clearMarkers();
      document.querySelectorAll('.list-btn').forEach(b => b.classList.remove('active'));

      if (isSameList) {
        activeListId = null;
        map.flyTo({ center: [-71.5, 44.0], zoom: 7, duration: 1000 });
        return;
      }

      activeListId = listId;
      document.querySelector(`[data-list-id="${listId}"]`)?.classList.add('active');

      const list = hikingLists.find(l => l.id === listId);
      if (!list) return;

      list.peaks.forEach(peak => {
        const popup = new mapboxgl.Popup({ offset: 20, closeButton: false, maxWidth: '320px' })
          .setHTML(buildPopupHTML(peak));

        const marker = new mapboxgl.Marker({ color: markerColor(), scale: 0.8 })
          .setLngLat(peak.coords)
          .addTo(map);

        const el = marker.getElement();
        el.addEventListener('mouseenter', () => popup.setLngLat(peak.coords).addTo(map));
        el.addEventListener('mouseleave', () => popup.remove());

        activeMarkers.push(marker);
      });

      const bounds = list.peaks.reduce((b, peak) => b.extend(peak.coords),
        new mapboxgl.LngLatBounds(list.peaks[0].coords, list.peaks[0].coords));
      map.fitBounds(bounds, { padding: 80, maxZoom: 10, duration: 1200 });
    }

    document.querySelectorAll('.list-btn').forEach(btn => {
      btn.addEventListener('click', () => showList(btn.dataset.listId));
    });

    // Trail search
    const trailsSearch = JSON.parse(trailsSearchJson);
    const searchInput = document.getElementById('trail-search');
    const searchResults = document.getElementById('search-results');

    searchInput.addEventListener('input', () => {
      const q = searchInput.value.trim().toLowerCase();
      searchResults.innerHTML = '';
      if (!q) return;

      const matches = trailsSearch.filter(t =>
        t.title.toLowerCase().includes(q) ||
        t.location.toLowerCase().includes(q)
      ).slice(0, 6);

      if (matches.length === 0) {
        searchResults.innerHTML = '<div class="search-no-results">No trails found</div>';
        return;
      }

      matches.forEach(t => {
        const a = document.createElement('a');
        a.href = `/trails/${t.id}`;
        a.className = 'search-result-item';
        a.innerHTML = `${t.title}<span class="search-result-location">${t.location}</span>`;
        searchResults.appendChild(a);
      });
    });
  </script>
</Base>
