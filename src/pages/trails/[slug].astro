---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { getCollection, render } from 'astro:content';
import { HIKING_LISTS } from '../../data/hikingLists';
import tzlookup from 'tz-lookup';

export async function getStaticPaths() {
  const trails = await getCollection('trails');
  return trails.map(trail => ({
    params: { slug: trail.id },
    props: { trail },
  }));
}

const { trail } = Astro.props;
const { Content } = await render(trail);

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

// Use coords from the MDX frontmatter if set; otherwise fall back to hikingLists lookup
const peakCoords: [number, number] | null =
  trail.data.peakCoords ??
  HIKING_LISTS.flatMap(list => list.peaks).find(p => p.trailSlug === trail.id)?.coords ??
  null;

const peakTz = peakCoords ? tzlookup(peakCoords[1], peakCoords[0]) : null;

const photosBase = (import.meta.env.PUBLIC_PHOTOS_BASE ?? '').replace(/\/$/, '');

const routeTypeLabel: Record<string, string> = {
  'loop':           'Loop',
  'out-and-back':   'Out & Back',
  'point-to-point': 'Point to Point',
};

function stars(n: number) {
  return '★'.repeat(n) + '☆'.repeat(5 - n);
}
---

<Base title={`${trail.data.title} — First Light Trails`}>
  <Fragment slot="head">
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.css" rel="stylesheet" />
    <script is:inline src="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.js"></script>
    <style>
      /* ── Hero ── */
      .hero {
        position: relative;
        height: 56vh;
        min-height: 360px;
        background: var(--bg-elevated);
        overflow: hidden;
      }

      .hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.75;
      }

      .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.80) 0%, rgba(0,0,0,0.05) 60%);
      }

      .hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 2.5rem 3rem;
      }

      .hero-location {
        font-family: system-ui, sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.65);
        margin-bottom: 0.5rem;
      }

      .hero-title {
        font-size: clamp(2rem, 5vw, 3.25rem);
        font-weight: normal;
        letter-spacing: 0.02em;
        color: #ffffff;
        line-height: 1.1;
        margin-bottom: 0.75rem;
      }

      .hero-summary {
        font-size: 1rem;
        color: rgba(255,255,255,0.80);
        max-width: 60ch;
        line-height: 1.6;
      }

      /* ── Stats bar ── */
      .stats-bar {
        display: flex;
        border-bottom: 1px solid var(--border);
        overflow-x: auto;
      }

      .stat {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        padding: 1.25rem 2rem;
        border-right: 1px solid var(--border);
        flex-shrink: 0;
      }

      .stat-label {
        font-family: system-ui, sans-serif;
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--label);
      }

      .stat-value {
        font-family: system-ui, sans-serif;
        font-size: 0.95rem;
        letter-spacing: 0.04em;
      }

      .stat-value.difficulty { text-transform: capitalize; }
      .stat-value.scenic { color: var(--accent); letter-spacing: 0.08em; }

      /* ── Routes ── */
      .routes-section {
        padding: 2.5rem 3rem;
        border-bottom: 1px solid var(--border);
      }

      .section-heading {
        font-family: system-ui, sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--label);
        margin-bottom: 1.25rem;
      }

      .routes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1rem;
      }

      .route-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 1.25rem 1.5rem;
      }

      .route-name {
        font-size: 0.95rem;
        color: var(--accent);
        margin-bottom: 0.75rem;
        letter-spacing: 0.02em;
      }

      .route-stats {
        display: flex;
        gap: 1.5rem;
        font-family: system-ui, sans-serif;
      }

      .route-stat {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }

      .route-stat-label {
        font-size: 0.62rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--label);
      }

      .route-stat-value {
        font-size: 0.95rem;
        letter-spacing: 0.04em;
      }

      .route-type-badge {
        display: inline-block;
        margin-top: 1rem;
        font-family: system-ui, sans-serif;
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
        background: var(--bg-elevated);
        padding: 0.2rem 0.5rem;
        border-radius: 2px;
      }

      /* ── Season ── */
      .season-section {
        padding: 1.5rem 3rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 1.25rem;
        font-family: system-ui, sans-serif;
      }

      .season-label {
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--label);
        flex-shrink: 0;
      }

      .season-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }

      .season-tag {
        font-size: 0.75rem;
        color: var(--text-muted);
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        padding: 0.2rem 0.65rem;
        border-radius: 2px;
        letter-spacing: 0.04em;
      }

      /* ── Prose body ── */
      .trail-body {
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 2rem 5rem;
        font-size: 1.05rem;
        line-height: 1.85;
        color: var(--text-body);
      }

      .trail-body :global(p),
      .trail-body :global(h2) {
        max-width: 65ch;
        margin-left: auto;
        margin-right: auto;
      }

      .trail-body :global(h2) {
        font-size: 1.2rem;
        font-weight: normal;
        color: var(--accent);
        letter-spacing: 0.04em;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--border);
      }

      .trail-body :global(p) { margin-bottom: 1.25rem; }
      .trail-body :global(p:last-child) { margin-bottom: 0; }

      /* ── Sun & Light ── */
      .sun-section {
        padding: 2rem 3rem;
        border-bottom: 1px solid var(--border);
      }

      .sun-section__date {
        font-family: system-ui, sans-serif;
        font-size: 0.65rem;
        letter-spacing: 0.08em;
        text-transform: none;
        color: var(--text-muted);
        margin-left: 0.5rem;
      }

      .sun-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 0.75rem;
      }

      .sun-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 0.85rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }

      .sun-card__label {
        font-family: system-ui, sans-serif;
        font-size: 0.62rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--label);
      }

      .sun-card__value {
        font-family: system-ui, sans-serif;
        font-size: 0.95rem;
        letter-spacing: 0.04em;
        color: var(--text-body);
      }

      /* ── Route map panel ── */
      .route-card { cursor: default; }
      .route-card.has-track { cursor: pointer; }
      .route-card.has-track:hover { border-color: var(--accent); }
      .route-card.active { border-color: var(--accent); background: var(--bg-elevated); }

      .track-map-panel {
        display: none;
        height: 340px;
        margin-top: 1.25rem;
        border: 1px solid var(--border);
        border-radius: 4px;
        overflow: hidden;
      }
      .track-map-panel.visible { display: block; }
      #track-map { width: 100%; height: 100%; }

      /* ── Back link ── */
      .back-link {
        padding: 0 2rem 3rem;
        max-width: 1100px;
        margin: 0 auto;
      }

      .back-link a {
        font-family: system-ui, sans-serif;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--label);
        text-decoration: none;
        transition: color 0.2s;
      }

      .back-link a:hover { color: var(--accent); }
    </style>
  </Fragment>

  <Nav active="trails" />

  <div class="hero">
    {trail.data.coverPhoto
      ? <img
          src={`${photosBase}/photos/${trail.data.coverPhoto}.webp`}
          alt={trail.data.coverImageAlt ?? trail.data.title}
        />
      : null
    }
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-location">{trail.data.location}</div>
      <h1 class="hero-title">{trail.data.title}</h1>
      <p class="hero-summary">{trail.data.summary}</p>
    </div>
  </div>

  <div class="stats-bar">
    <div class="stat">
      <span class="stat-label">Difficulty</span>
      <span class="stat-value difficulty" style={`color: var(--difficulty-${trail.data.difficulty})`}>
        {trail.data.difficulty}
      </span>
    </div>
    <div class="stat">
      <span class="stat-label">Scenic</span>
      <span class="stat-value scenic">{stars(trail.data.scenicRating)}</span>
    </div>
    {trail.data.routes[0] && (
      <div class="stat">
        <span class="stat-label">Distance</span>
        <span class="stat-value">{trail.data.routes[0].distance} mi</span>
      </div>
    )}
    {trail.data.routes[0] && (
      <div class="stat">
        <span class="stat-label">Elevation Gain</span>
        <span class="stat-value">+{trail.data.routes[0].elevationGain.toLocaleString()} ft</span>
      </div>
    )}
    {trail.data.hikingLists && trail.data.hikingLists.length > 0 && (
      <div class="stat">
        <span class="stat-label">Lists</span>
        <span class="stat-value" style="font-size:0.8rem; color: var(--text-muted);">
          {trail.data.hikingLists.join(', ')}
        </span>
      </div>
    )}
  </div>

  {peakCoords && (
    <div class="sun-section" data-lng={peakCoords[0]} data-lat={peakCoords[1]} data-tz={peakTz}>
      <div class="section-heading">
        Sun &amp; Light <span class="sun-section__date" data-sun="date"></span>
      </div>
      <div class="sun-grid">
        <div class="sun-card">
          <span class="sun-card__label">Sunrise</span>
          <span class="sun-card__value" data-sun="sunrise">—</span>
        </div>
        <div class="sun-card">
          <span class="sun-card__label">Golden Hour AM</span>
          <span class="sun-card__value" data-sun="goldenAM">—</span>
        </div>
        <div class="sun-card">
          <span class="sun-card__label">Golden Hour PM</span>
          <span class="sun-card__value" data-sun="goldenPM">—</span>
        </div>
        <div class="sun-card">
          <span class="sun-card__label">Sunset</span>
          <span class="sun-card__value" data-sun="sunset">—</span>
        </div>
        <div class="sun-card">
          <span class="sun-card__label">Day Length</span>
          <span class="sun-card__value" data-sun="daylength">—</span>
        </div>
      </div>
    </div>
  )}

  {trail.data.routes.length > 0 && (
    <div class="routes-section">
      <div class="section-heading">Route Options</div>
      <div class="routes-grid">
        {trail.data.routes.map(route => (
          <div class={`route-card${route.track ? ' has-track' : ''}`} data-track={route.track ?? ''}>
            <div class="route-name">{route.name}</div>
            <div class="route-stats">
              <div class="route-stat">
                <span class="route-stat-label">Distance</span>
                <span class="route-stat-value">{route.distance} mi</span>
              </div>
              <div class="route-stat">
                <span class="route-stat-label">Gain</span>
                <span class="route-stat-value">+{route.elevationGain.toLocaleString()} ft</span>
              </div>
            </div>
            <span class="route-type-badge">{routeTypeLabel[route.type]}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="track-map-panel" id="track-map-panel">
    <div id="track-map"></div>
  </div>

  {trail.data.bestSeason.length > 0 && (
    <div class="season-section">
      <span class="season-label">Best Season</span>
      <div class="season-tags">
        {trail.data.bestSeason.map(s => (
          <span class="season-tag">{s}</span>
        ))}
      </div>
    </div>
  )}

  <div class="trail-body">
    <Content />
  </div>

  <div class="back-link">
    <a href="/trails">← All Trails</a>
  </div>

  <script define:vars={{ mapboxToken }}>
    const panel = document.getElementById('track-map-panel');
    const cards  = document.querySelectorAll('.route-card.has-track');
    if (!cards.length) return;

    mapboxgl.accessToken = mapboxToken;
    let map = null;
    let activeCard = null;

    function initMap() {
      if (map) return;
      map = new mapboxgl.Map({
        container: 'track-map',
        style: 'mapbox://styles/mapbox/outdoors-v12',
        center: [-71.2, 44.32],
        zoom: 12,
      });
      map.addControl(new mapboxgl.NavigationControl(), 'bottom-right');
    }

    function loadTrack(trackName) {
      fetch(`/tracks/${trackName}.geojson`)
        .then(r => r.json())
        .then(geojson => {
          if (map.getSource('track')) {
            map.getSource('track').setData(geojson);
          } else {
            map.addSource('track', { type: 'geojson', data: geojson });
            map.addLayer({
              id: 'track-line',
              type: 'line',
              source: 'track',
              layout: { 'line-join': 'round', 'line-cap': 'round' },
              paint: { 'line-color': '#3b82f6', 'line-width': 3, 'line-opacity': 0.9 },
            });
          }

          // Fit map to track bounds
          const coords = geojson.features.flatMap(f =>
            f.geometry.type === 'MultiLineString'
              ? f.geometry.coordinates.flat()
              : f.geometry.coordinates
          );
          if (coords.length) {
            const bounds = coords.reduce(
              (b, c) => b.extend(c),
              new mapboxgl.LngLatBounds(coords[0], coords[0])
            );
            map.fitBounds(bounds, { padding: 40, duration: 800 });
          }
        });
    }

    function activateCard(card) {
      const trackName = card.dataset.track;
      if (!trackName) return;
      cards.forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      activeCard = card;
      panel.classList.add('visible');
      if (!map) {
        initMap();
        map.on('load', () => loadTrack(trackName));
      } else {
        loadTrack(trackName);
      }
    }

    cards.forEach(card => {
      card.addEventListener('click', () => {
        if (activeCard === card) {
          card.classList.remove('active');
          panel.classList.remove('visible');
          activeCard = null;
        } else {
          activateCard(card);
        }
      });
    });

    // Auto-show the first route that has a track
    activateCard(cards[0]);
  </script>

  <script>
    import SunCalc from 'suncalc';

    const section = document.querySelector<HTMLElement>('.sun-section');
    if (section) {
      const lng = parseFloat(section.dataset.lng!);
      const lat = parseFloat(section.dataset.lat!);
      const tz  = section.dataset.tz!;
      const now = new Date();
      const t = SunCalc.getTimes(now, lat, lng);

      const fmtTime = (d: Date) =>
        new Intl.DateTimeFormat('en-US', {
          hour: 'numeric', minute: '2-digit', timeZone: tz,
        }).format(d);
      const fmtDate = (d: Date) =>
        new Intl.DateTimeFormat('en-US', {
          month: 'short', day: 'numeric', timeZone: tz,
        }).format(d);

      const set = (key: string, value: string) => {
        const el = section.querySelector(`[data-sun="${key}"]`);
        if (el) el.textContent = value;
      };

      set('date', `· today, ${fmtDate(now)}`);
      set('sunrise',  fmtTime(t.sunrise));
      set('sunset',   fmtTime(t.sunset));
      set('goldenAM', `${fmtTime(t.sunrise)} – ${fmtTime(t.goldenHourEnd)}`);
      set('goldenPM', `${fmtTime(t.goldenHour)} – ${fmtTime(t.sunset)}`);

      const ms = t.sunset.getTime() - t.sunrise.getTime();
      const h = Math.floor(ms / 3_600_000);
      const m = Math.floor((ms % 3_600_000) / 60_000);
      set('daylength', `${h}h ${m}m`);
    }
  </script>
</Base>
