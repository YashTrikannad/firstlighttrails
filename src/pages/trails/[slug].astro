---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const trails = await getCollection('trails');
  return trails.map(trail => ({
    params: { slug: trail.id },
    props: { trail },
  }));
}

const { trail } = Astro.props;
const { Content } = await render(trail);

const photosBase = (import.meta.env.PUBLIC_PHOTOS_BASE ?? '').replace(/\/$/, '');

const difficultyColor: Record<string, string> = {
  easy:      '#5a8a5a',
  moderate:  '#a0b09a',
  hard:      '#c8b89a',
  strenuous: '#c87a5a',
};

const routeTypeLabel: Record<string, string> = {
  'loop':            'Loop',
  'out-and-back':    'Out & Back',
  'point-to-point':  'Point to Point',
};

function stars(n: number) {
  return '★'.repeat(n) + '☆'.repeat(5 - n);
}

const color = difficultyColor[trail.data.difficulty];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{trail.data.title} — Trail & Frame</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: Georgia, serif;
        background: #0f1a0f;
        color: #e8e0d0;
        min-height: 100vh;
      }

      /* ── Nav ── */
      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 3rem;
        border-bottom: 1px solid #1e2e1e;
      }

      nav .logo {
        font-size: 1.1rem;
        font-weight: bold;
        letter-spacing: 0.05em;
        color: #c8b89a;
        text-decoration: none;
      }

      nav ul { list-style: none; display: flex; gap: 2rem; }

      nav a {
        color: #e8e0d0;
        text-decoration: none;
        font-family: system-ui, sans-serif;
        font-size: 0.82rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        transition: color 0.2s;
      }

      nav a:hover { color: #c8b89a; }

      /* ── Hero ── */
      .hero {
        position: relative;
        height: 56vh;
        min-height: 360px;
        background: #141f14;
        overflow: hidden;
      }

      .hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.55;
      }

      .hero-no-photo {
        width: 100%;
        height: 100%;
        background: linear-gradient(160deg, #141f14 0%, #0f1a0f 100%);
      }

      .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(15,26,15,0.9) 0%, transparent 60%);
      }

      .hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 2.5rem 3rem;
      }

      .hero-location {
        font-family: system-ui, sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #a0b09a;
        margin-bottom: 0.5rem;
      }

      .hero-title {
        font-size: clamp(2rem, 5vw, 3.25rem);
        font-weight: normal;
        letter-spacing: 0.02em;
        color: #e8e0d0;
        line-height: 1.1;
        margin-bottom: 0.75rem;
      }

      .hero-summary {
        font-size: 1rem;
        color: #b8b0a0;
        max-width: 60ch;
        line-height: 1.6;
      }

      /* ── Stats bar ── */
      .stats-bar {
        display: flex;
        gap: 0;
        border-bottom: 1px solid #1e2e1e;
        overflow-x: auto;
      }

      .stat {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        padding: 1.25rem 2rem;
        border-right: 1px solid #1e2e1e;
        flex-shrink: 0;
      }

      .stat-label {
        font-family: system-ui, sans-serif;
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #6a8a6a;
      }

      .stat-value {
        font-family: system-ui, sans-serif;
        font-size: 0.95rem;
        color: #e8e0d0;
        letter-spacing: 0.04em;
      }

      .stat-value.difficulty {
        text-transform: capitalize;
      }

      .stat-value.scenic { color: #c8b89a; letter-spacing: 0.08em; }

      /* ── Routes ── */
      .routes-section {
        padding: 2.5rem 3rem;
        border-bottom: 1px solid #1e2e1e;
      }

      .section-heading {
        font-family: system-ui, sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #6a8a6a;
        margin-bottom: 1.25rem;
      }

      .routes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1rem;
      }

      .route-card {
        background: #141f14;
        border: 1px solid #2a3a2a;
        border-radius: 4px;
        padding: 1.25rem 1.5rem;
      }

      .route-name {
        font-size: 0.95rem;
        color: #c8b89a;
        margin-bottom: 0.75rem;
        letter-spacing: 0.02em;
      }

      .route-stats {
        display: flex;
        gap: 1.5rem;
        font-family: system-ui, sans-serif;
      }

      .route-stat {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }

      .route-stat-label {
        font-size: 0.62rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #6a8a6a;
      }

      .route-stat-value {
        font-size: 0.95rem;
        color: #e8e0d0;
        letter-spacing: 0.04em;
      }

      .route-type-badge {
        display: inline-block;
        margin-top: 1rem;
        font-family: system-ui, sans-serif;
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #a0b09a;
        background: #1e2e1e;
        padding: 0.2rem 0.5rem;
        border-radius: 2px;
      }

      /* ── Best season ── */
      .season-section {
        padding: 1.5rem 3rem;
        border-bottom: 1px solid #1e2e1e;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        font-family: system-ui, sans-serif;
      }

      .season-label {
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #6a8a6a;
        flex-shrink: 0;
      }

      .season-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .season-tag {
        font-size: 0.75rem;
        color: #a0b09a;
        background: #1a2a1a;
        border: 1px solid #2a3a2a;
        padding: 0.2rem 0.65rem;
        border-radius: 2px;
        letter-spacing: 0.04em;
      }

      /* ── Prose body ── */
      .trail-body {
        max-width: 72ch;
        margin: 0 auto;
        padding: 3rem 2rem 5rem;
        font-size: 1.05rem;
        line-height: 1.85;
        color: #d8d0c0;
      }

      .trail-body :global(h2) {
        font-size: 1.2rem;
        font-weight: normal;
        color: #c8b89a;
        letter-spacing: 0.04em;
        margin: 2.5rem 0 1rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid #2a3a2a;
      }

      .trail-body :global(p) {
        margin-bottom: 1.25rem;
      }

      .trail-body :global(p:last-child) { margin-bottom: 0; }

      /* TrailPhoto component styles are scoped inside the component */
      /* but we need to allow the bleed effect from inside prose */
      .trail-body {
        overflow-x: hidden;
      }

      /* ── Back link ── */
      .back-link {
        padding: 0 3rem 3rem;
        max-width: calc(72ch + 4rem);
        margin: 0 auto;
      }

      .back-link a {
        font-family: system-ui, sans-serif;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6a8a6a;
        text-decoration: none;
        transition: color 0.2s;
      }

      .back-link a:hover { color: #c8b89a; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="logo">Trail & Frame</a>
      <ul>
        <li><a href="/trails">Trails</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>

    <!-- Hero -->
    <div class="hero">
      {trail.data.coverPhoto
        ? <img
            src={`${photosBase}/photos/${trail.data.coverPhoto}.webp`}
            alt={trail.data.coverImageAlt ?? trail.data.title}
          />
        : <div class="hero-no-photo"></div>
      }
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <div class="hero-location">{trail.data.location}</div>
        <h1 class="hero-title">{trail.data.title}</h1>
        <p class="hero-summary">{trail.data.summary}</p>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="stats-bar">
      <div class="stat">
        <span class="stat-label">Difficulty</span>
        <span class="stat-value difficulty" style={`color: ${color}`}>{trail.data.difficulty}</span>
      </div>
      <div class="stat">
        <span class="stat-label">Scenic</span>
        <span class="stat-value scenic">{stars(trail.data.scenicRating)}</span>
      </div>
      {trail.data.routes[0] && (
        <div class="stat">
          <span class="stat-label">Distance</span>
          <span class="stat-value">{trail.data.routes[0].distance} mi</span>
        </div>
      )}
      {trail.data.routes[0] && (
        <div class="stat">
          <span class="stat-label">Elevation Gain</span>
          <span class="stat-value">+{trail.data.routes[0].elevationGain.toLocaleString()} ft</span>
        </div>
      )}
      {trail.data.hikingLists && trail.data.hikingLists.length > 0 && (
        <div class="stat">
          <span class="stat-label">Lists</span>
          <span class="stat-value" style="font-size: 0.8rem; color: #a0b09a;">
            {trail.data.hikingLists.join(', ')}
          </span>
        </div>
      )}
    </div>

    <!-- Routes -->
    {trail.data.routes.length > 0 && (
      <div class="routes-section">
        <div class="section-heading">Route Options</div>
        <div class="routes-grid">
          {trail.data.routes.map(route => (
            <div class="route-card">
              <div class="route-name">{route.name}</div>
              <div class="route-stats">
                <div class="route-stat">
                  <span class="route-stat-label">Distance</span>
                  <span class="route-stat-value">{route.distance} mi</span>
                </div>
                <div class="route-stat">
                  <span class="route-stat-label">Gain</span>
                  <span class="route-stat-value">+{route.elevationGain.toLocaleString()} ft</span>
                </div>
              </div>
              <span class="route-type-badge">{routeTypeLabel[route.type]}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Best season -->
    {trail.data.bestSeason.length > 0 && (
      <div class="season-section">
        <span class="season-label">Best Season</span>
        <div class="season-tags">
          {trail.data.bestSeason.map(s => (
            <span class="season-tag">{s}</span>
          ))}
        </div>
      </div>
    )}

    <!-- Trail description body (MDX) -->
    <div class="trail-body">
      <Content />
    </div>

    <div class="back-link">
      <a href="/trails">← All Trails</a>
    </div>
  </body>
</html>
