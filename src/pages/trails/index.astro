---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const trails = await getCollection('trails');
const photosBase = (import.meta.env.PUBLIC_PHOTOS_BASE ?? '').replace(/\/$/, '');

function stars(n: number) {
  return '★'.repeat(n) + '☆'.repeat(5 - n);
}
---

<Base title="Trail Guides — First Light Trails">
  <Fragment slot="head">
    <style>
      .page-header {
        padding: 4rem 3rem 2.5rem;
        border-bottom: 1px solid var(--border);
      }

      .page-header h1 {
        font-size: 2rem;
        font-weight: normal;
        letter-spacing: 0.02em;
        margin-bottom: 0.5rem;
      }

      .page-header p {
        font-family: system-ui, sans-serif;
        font-size: 0.85rem;
        color: var(--text-muted);
        letter-spacing: 0.04em;
      }

      .trail-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
        padding: 2.5rem 3rem;
        max-width: 1400px;
      }

      .trail-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 4px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        transition: border-color 0.2s, transform 0.15s;
      }

      .trail-card:hover {
        border-color: var(--border-hover);
        transform: translateY(-2px);
      }

      .trail-card-img {
        height: 200px;
        background: var(--bg-elevated);
        overflow: hidden;
      }

      .trail-card-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.9;
        transition: opacity 0.2s;
      }

      .trail-card:hover .trail-card-img img { opacity: 1; }

      .no-photo {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--border-hover);
        font-family: system-ui, sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .trail-card-body {
        padding: 1.25rem 1.5rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex: 1;
      }

      .trail-card-location {
        font-family: system-ui, sans-serif;
        font-size: 0.72rem;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .trail-card-title {
        font-size: 1.1rem;
        font-weight: normal;
        letter-spacing: 0.02em;
      }

      .trail-card-summary {
        font-size: 0.88rem;
        color: var(--text-subtle);
        line-height: 1.6;
        flex: 1;
      }

      .trail-card-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        padding-top: 0.75rem;
        border-top: 1px solid var(--border);
        font-family: system-ui, sans-serif;
        font-size: 0.75rem;
      }

      .badge-difficulty {
        padding: 0.2rem 0.6rem;
        border-radius: 2px;
        border: 1px solid currentColor;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        font-size: 0.68rem;
        opacity: 0.85;
      }

      .trail-meta-stat {
        color: var(--text-muted);
        letter-spacing: 0.04em;
      }

      .trail-meta-stat span { color: var(--text); margin-right: 0.2rem; }

      .scenic-stars {
        color: var(--accent);
        letter-spacing: 0.05em;
        font-size: 0.75rem;
        margin-left: auto;
      }

      .empty-state {
        padding: 4rem 3rem;
        color: var(--text-muted);
        font-family: system-ui, sans-serif;
        font-size: 0.9rem;
      }
    </style>
  </Fragment>

  <Nav active="trails" />

  <div class="page-header">
    <h1>Trail Guides</h1>
    <p>{trails.length} {trails.length === 1 ? 'guide' : 'guides'} — New England & beyond</p>
  </div>

  {trails.length === 0 ? (
    <div class="empty-state">No trail guides yet — check back soon.</div>
  ) : (
    <div class="trail-grid">
      {trails.map(trail => {
        const mainRoute = trail.data.routes[0];
        const diff = trail.data.difficulty;
        return (
          <a href={`/trails/${trail.id}`} class="trail-card">
            <div class="trail-card-img">
              {trail.data.coverPhoto
                ? <img
                    src={`${photosBase}/photos/${trail.data.coverPhoto}.webp`}
                    alt={trail.data.coverImageAlt ?? trail.data.title}
                    loading="lazy"
                    decoding="async"
                  />
                : <div class="no-photo">No photo yet</div>
              }
            </div>
            <div class="trail-card-body">
              <div>
                <div class="trail-card-location">{trail.data.location}</div>
                <div class="trail-card-title">{trail.data.title}</div>
              </div>
              <div class="trail-card-summary">{trail.data.summary}</div>
              <div class="trail-card-meta">
                <span class="badge-difficulty" style={`color: var(--difficulty-${diff})`}>
                  {diff}
                </span>
                {mainRoute && (
                  <span class="trail-meta-stat"><span>{mainRoute.distance}</span>mi</span>
                )}
                {mainRoute && (
                  <span class="trail-meta-stat"><span>+{mainRoute.elevationGain.toLocaleString()}</span>ft</span>
                )}
                <span class="scenic-stars" title={`Scenic: ${trail.data.scenicRating}/5`}>
                  {stars(trail.data.scenicRating)}
                </span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  )}
</Base>
