---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* Light mode */
    --bg:           #f8f6f2;
    --bg-card:      #ffffff;
    --bg-elevated:  #eeebe6;
    --bg-overlay:   rgba(248, 246, 242, 0.93);
    --border:       #dbd7d0;
    --border-hover: #b0aca4;
    --text:         #1a1814;
    --text-body:    #302c26;
    --text-subtle:  #524e48;
    --text-muted:   #706860;
    --accent:       #7a5018;
    --accent-soft:  #a07838;
    --label:        #908070;
    --nav-gradient: linear-gradient(to bottom, rgba(248,246,242,0.90) 0%, transparent 100%);
    --popup-bg:     #ffffff;
    --popup-border: #dbd7d0;
    --difficulty-easy:      #287028;
    --difficulty-moderate:  #606858;
    --difficulty-hard:      #7a5018;
    --difficulty-strenuous: #982818;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg:           #0a0a0a;
      --bg-card:      #141414;
      --bg-elevated:  #1c1c1c;
      --bg-overlay:   rgba(10, 10, 10, 0.90);
      --border:       #262626;
      --border-hover: #484848;
      --text:         #e8e0d0;
      --text-body:    #d8d0c0;
      --text-subtle:  #b8b0a0;
      --text-muted:   #888278;
      --accent:       #c8b89a;
      --accent-soft:  #c8b89a;
      --label:        #707868;
      --nav-gradient: linear-gradient(to bottom, rgba(10,10,10,0.88) 0%, transparent 100%);
      --popup-bg:     #1a1a1a;
      --popup-border: #2a2a2a;
      --difficulty-easy:      #5a8a5a;
      --difficulty-moderate:  #a0a890;
      --difficulty-hard:      #c8b89a;
      --difficulty-strenuous: #c87a5a;
    }
  }

  body {
    font-family: Georgia, serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }
</style>
